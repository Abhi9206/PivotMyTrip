# NomadAI Environment Configuration
# Copy this file to .env and fill in your values

# ── Groq API (Required for LLM + Voice) ─────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY="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"

# ── Ollama (Optional fallback LLM) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhst:11434
OLLAMA_MODEL=llama3

# ── OSRM Routing (Optional — uses public demo by default) ──────────────────
# Use the public demo server (rate limited) or self-host:
# https://github.com/Project-OSRM/osrm-backend
OSRM_BASE_URL=https://router.project-osrm.org

# ── Nominatim Geocoding (Optional — uses public server by default) ─────────
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ── Cache ──────────────────────────────────────────────────────────────────
CACHE_DIR=data/cache
ROUTE_CACHE_TTL_SECONDS=3600

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
